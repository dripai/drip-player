{
  "productName": "drip-player",
  "version": "1.0.1",
  "identifier": "com.drip.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "pnpm build:tauri",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Drip Player",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../lib": "lib"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGQUJBODUyQUMzRjRDQTUKUldTbFREK3NVcWlyZjBjaFBabGdIR2hlL0MvNHJOUTR4K0wwY0EzN1dtS1JtOXZGaldBVjZGUFcK",
      "endpoints": [
        "https://github.com/dripai/drip-player/releases/latest/download/latest.json"
      ]
    }
  }
}
